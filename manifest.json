{
  "manifest_version": 3,
  "name": "Global Grayscale Toggle",
  "version": "1.0.0",
  "description": "Toggle grayscale mode on all webpages.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Grayscale Toggle",
    "default_popup": "popup.html"
  },
  "commands": {
    "toggle-grayscale": {
      "suggested_key": {
        "default": "Ctrl+Shift+G",
        "mac": "Command+Shift+G"
      },
      "description": "Toggle grayscale mode"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
